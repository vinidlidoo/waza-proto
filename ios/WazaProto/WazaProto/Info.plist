<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleDisplayName</key>
	<string>Waza</string>
	<!-- Screen broadcast (plan 25): our extension uses Xcode's default bundle id
	     (….WazaProtoBroadcast) rather than LiveKit's assumed `<app>.broadcast`,
	     so pin both identifiers. RTCScreenSharingExtension lets the system picker
	     preselect our extension; RTCAppGroupIdentifier fixes the IPC socket path. -->
	<key>RTCAppGroupIdentifier</key>
	<string>group.com.vincent.WazaProto</string>
	<key>RTCScreenSharingExtension</key>
	<string>com.vincent.WazaProto.WazaProtoBroadcast</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>wazaproto</string>
			</array>
		</dict>
	</array>
	<key>UISupportedExternalAccessoryProtocols</key>
	<array>
		<string>com.meta.ar.wearable</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>processing</string>
		<string>bluetooth-central</string>
		<string>bluetooth-peripheral</string>
		<string>external-accessory</string>
	</array>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Waza Proto connects to Ray-Ban Meta glasses over Bluetooth to stream their camera.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Waza Proto discovers Ray-Ban Meta glasses on the local network for higher-bandwidth streaming.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_bonjour._tcp</string>
		<string>_wazaproto-preflight._tcp</string>
	</array>
	<!-- Permits cleartext HTTP only to localhost / *.local / link-local, so a
	     DEBUG build with WAZA_VIEWER_HOST can reach a `vercel dev` (simulator via
	     localhost, device via the Mac's .local host). Prod HTTPS stays enforced. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>MWDAT</key>
	<dict>
		<key>AppLinkURLScheme</key>
		<string>wazaproto://</string>
		<key>MetaAppID</key>
		<string>0</string>
		<key>TeamID</key>
		<string>$(DEVELOPMENT_TEAM)</string>
		<key>DAMEnabled</key>
		<true/>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>Waza Proto publishes your camera to demonstrate the streaming pipeline.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Waza Proto initializes audio capture as a side-effect of the camera pipeline.</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
